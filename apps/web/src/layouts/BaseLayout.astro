---
import "../styles.css";

const {
  title = "韭菜圈",
  description = "A 股 ETF/股票条件单辅助计算与策略复盘工具。"
} = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-rice text-ink">
    <header class="border-b border-line bg-rice/95">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="text-xl font-bold tracking-normal">韭菜圈</a>
        <div class="flex items-center gap-4 text-sm">
          <a class="hover:text-leaf" href="/tools/condition-order">条件单工具</a>
          <a class="hover:text-leaf" href="/strategies/condition-order">策略说明</a>
          <a class="hover:text-leaf" href="/log">迭代日志</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-16 border-t border-line bg-white/45">
      <div class="mx-auto max-w-6xl px-4 py-8 text-sm leading-7 text-stone-700">
        <p class="font-semibold text-ink">风险提示</p>
        <p>本站内容和工具仅用于投资学习、策略研究和条件单辅助计算，不构成证券投资建议，不承诺收益。市场有风险，投资需独立判断。</p>
      </div>
    </footer>
  </body>
</html>
